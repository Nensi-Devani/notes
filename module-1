Error :		interface A { 
    default void demo() {
        System.out.println("A");
    }
}

interface B {
    default void demo() {
        System.out.println("B");
    }
}

class C implements A, B {
}

Solution: 
	interface A {
    default void demo() {
        System.out.println("A");
    }
}

interface B {
    default void demo() {
        System.out.println("B");
    }
}

class C implements A, B {
    @Override
    public void demo() {
        A.super.demo();   // or B.super.demo() // Use the default implementation provided by this interface.
    }
}

public class Main {
    public static void main(String[] args) {
        C c = new C();
        c.demo();
    }
}

